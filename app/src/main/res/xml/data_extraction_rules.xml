<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="file" path="autosave" />
        <include domain="file" path="freeze_frames" />
        <include domain="file" path="voiceovers" />
        <include domain="file" path="tts_output" />
        <include domain="file" path="tts" />
        <include domain="file" path="noise_reduced" />
        <exclude domain="file" path="autosave/*.tmp" />
        <exclude domain="file" path="tts_output/*.partial.wav" />
        <exclude domain="file" path="tts/*.partial.wav" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="file" path="autosave" />
        <include domain="file" path="freeze_frames" />
        <include domain="file" path="voiceovers" />
        <include domain="file" path="tts_output" />
        <include domain="file" path="tts" />
        <include domain="file" path="noise_reduced" />
        <exclude domain="file" path="autosave/*.tmp" />
        <exclude domain="file" path="tts_output/*.partial.wav" />
        <exclude domain="file" path="tts/*.partial.wav" />
    </device-transfer>
</data-extraction-rules>
