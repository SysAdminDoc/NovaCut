<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <include domain="database" path="." />
    <include domain="file" path="autosave" />
    <include domain="file" path="freeze_frames" />
    <include domain="file" path="voiceovers" />
    <!-- Preserve generated timeline media so projects round-trip cleanly across
         device transfers. Without these, a restored project's clips that reference these
         files would resolve to dangling URIs and disappear from the timeline. -->
    <include domain="file" path="tts_output" />
    <include domain="file" path="tts" />
    <include domain="file" path="noise_reduced" />
    <include domain="file" path="stabilized" />
    <exclude domain="file" path="autosave/*.tmp" />
    <exclude domain="file" path="freeze_frames/*.partial.jpg" />
    <exclude domain="file" path="voiceovers/*.partial.m4a" />
    <exclude domain="file" path="tts_output/*.partial.wav" />
    <exclude domain="file" path="tts/*.partial.wav" />
    <exclude domain="file" path="noise_reduced/*.partial.m4a" />
    <exclude domain="file" path="stabilized/*.partial.mp4" />
</full-backup-content>
